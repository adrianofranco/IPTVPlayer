# Copie para .env.local (gitignored) e preencha com a base do seu provider Xtream.
# Apenas host:porta, SEM barra final e SEM usuario/senha (esses vao em runtime).
# Ex.: VITE_XTREAM_BASE=http://seu-host:8080
VITE_XTREAM_BASE=

# VITE_DEV_TIME=true embute a lista acima no build/wgt (conveniencia p/ testar na
# TV sem digitar a URL). ATENCAO: com 'true', credenciais ENTRAM no bundle.
# Deixe vazio/false no build "de verdade" p/ o usuario cadastrar a fonte na UI.
VITE_DEV_TIME=false
